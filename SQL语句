mysql -h{ip} -u{用户} -p{密码} -D{数据库} -e{要执行的语句} -A

删除数据库某个范围内的数据：
CREATE TEMPORARY TABLE {临时表} 
SELECT id FROM {数据表}
WHERE {条件};

DELETE FROM {数据表} 
WHERE id IN (SELECT id FROM {临时表});

DROP TEMPORARY TABLE {临时表};



建表语句CREATE TABLE cert (
  id INT  UNIQUE AUTO_INCREMENT,
  domain VARCHAR(255)  NULL,
  fingerprint VARCHAR(255) NULL,
  issuer VARCHAR(255) NULL,
  expiration_date DATE NULL,
  remaining_days INT NULL,
  PRIMARY KEY (id)
);
